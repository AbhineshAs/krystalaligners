<!-- About Section -->
    <section id="about" class="py-6 bg-light">
        <div class="container py-5 reveal-up">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="position-relative">
                        <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=800"
                            alt="Clinic Interior" class="img-fluid rounded-4 shadow-lg">
                        <div
                            class="experience-badge bg-white shadow p-3 rounded-4 position-absolute bottom-0 end-0 translate-middle-y me-n4 d-none d-md-block text-center border-bottom border-4 border-teal">
                            <h3 class="fw-bold text-teal mb-0"><span class="counter" data-target="10">0</span>+</h3>
                            <p class="text-muted small mb-0">Years Exp</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 ps-lg-5">
                    <div class="title-wrapper mb-4">
                        <span class="text-teal font-monospace text-uppercase small fw-bold tracking-wide">About
                            Us</span>
                        <h2 class="display-5 fw-bold mt-2 text-dark">Your Journey to a Perfect Smile Starts Here</h2>
                    </div>
                    <p class="text-secondary lead mb-4">We specialize in providing top-tier, nearly invisible clear
                        aligners that straighten your teeth comfortably and efficiently. Say goodbye to traditional
                        metal braces.</p>

                    <div class="row g-4 mt-2">
                        <div class="col-6 col-md-3 text-center">
                            <div
                                class="counter-box bg-white p-3 rounded-4 shadow-sm h-100 border-bottom border-3 border-teal hover-lift">
                                <h3 class="fw-bold text-teal mb-1"><span class="counter" data-target="5000">0</span>+
                                </h3>
                                <p class="small text-muted mb-0">Happy Patients</p>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 text-center">
                            <div
                                class="counter-box bg-white p-3 rounded-4 shadow-sm h-100 border-bottom border-3 border-teal hover-lift">
                                <h3 class="fw-bold text-teal mb-1"><span class="counter" data-target="10">0</span>+</h3>
                                <p class="small text-muted mb-0">Years Experience</p>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 text-center">
                            <div
                                class="counter-box bg-white p-3 rounded-4 shadow-sm h-100 border-bottom border-3 border-teal hover-lift">
                                <h3 class="fw-bold text-teal mb-1"><span class="counter" data-target="50">0</span>+</h3>
                                <p class="small text-muted mb-0">Clinics</p>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 text-center">
