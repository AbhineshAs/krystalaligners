            </div>

            <div class="row g-4 justify-content-center">
                <!-- Doctor 1 -->
                <div class="col-md-6 col-lg-4 reveal-up">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 hover-scale-card">
                        <div class="card-img-wrapper" style="height: 300px; overflow: hidden;">
                            <img src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&q=80&w=600"
                                class="card-img-top w-100 h-100 object-fit-cover" alt="Dr. John Doe">
                        </div>
                        <div class="card-body p-4 text-center bg-white position-relative z-1 pt-4">
                            <h4 class="fw-bold text-dark mb-1">Dr. Robert Chen</h4>
                            <p class="text-teal mb-2 fw-medium">Lead Orthodontist</p>
                            <p class="text-muted small mb-3">DDS, MS · 15+ Yrs Experience</p>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="#" class="btn btn-light btn-sm rounded-circle"><i
                                        class="fa-brands fa-linkedin-in text-teal"></i></a>
                                <a href="#" class="btn btn-light btn-sm rounded-circle"><i
                                        class="fa-brands fa-twitter text-teal"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Doctor 2 -->
                <div class="col-md-6 col-lg-4 reveal-up" style="transition-delay: 100ms;">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 hover-scale-card">
                        <div class="card-img-wrapper" style="height: 300px; overflow: hidden;">
                            <img src="https://images.unsplash.com/photo-1594824436951-7f12bc00ceec?auto=format&fit=crop&q=80&w=600"
                                class="card-img-top w-100 h-100 object-fit-cover" alt="Dr. Jane Smith">
                        </div>
                        <div class="card-body p-4 text-center bg-white position-relative z-1 pt-4">
                            <h4 class="fw-bold text-dark mb-1">Dr. Jessica Morgan</h4>
                            <p class="text-teal mb-2 fw-medium">Clear Aligner Specialist</p>
                            <p class="text-muted small mb-3">DMD · 10+ Yrs Experience</p>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="#" class="btn btn-light btn-sm rounded-circle"><i
                                        class="fa-brands fa-linkedin-in text-teal"></i></a>
