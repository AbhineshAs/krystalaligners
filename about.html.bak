                                class="card-img-top w-100 h-100 object-fit-cover" alt="Dr. Alan Williams">
                        </div>
                        <div class="card-body p-4 text-center bg-white position-relative z-1 pt-4">
                            <h4 class="fw-bold text-dark mb-1">Dr. Alan Williams</h4>
                            <p class="text-teal mb-2 fw-medium">Cosmetic Dentist</p>
                            <p class="text-muted small mb-3">DDS · 12+ Yrs Experience</p>
                            <div class="d-flex justify-content-center gap-2">
