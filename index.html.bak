    <!-- Hero Section -->
    <section id="home" class="hero-section d-flex align-items-center position-relative">
        <div class="container position-relative z-1 text-center text-md-start">
            <div class="row">
                <div class="col-lg-7 text-white reveal-up">
                    <h1 class="display-3 fw-bold mb-4 text-shadow">Transform Your Smile with Clear Aligners</h1>
                    <p class="lead mb-5 fw-light text-shadow">Invisible braces for confident smiles. Experience the most
                        advanced clear aligner clear treatment today.</p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-md-start">
                        <a href="#contact" class="btn btn-teal btn-lg rounded-pill px-5 shadow">Book Appointment</a>
                        <a href="about.html" class="btn btn-outline-light btn-lg rounded-pill px-5">Learn More</a>
                    </div>
                </div>
            </div>
        </div>
        <a href="#how-it-works" class="scroll-down-btn text-white">
            <i class="fa-solid fa-chevron-down"></i>
        </a>
    </section>

    
    
    <!-- How It Works Section -->
    <section id="how-it-works" class="py-6 bg-teal text-white">
        <div class="container py-5">
            <div class="text-center mb-5 reveal-up">
                <span class="text-light font-monospace text-uppercase small fw-bold tracking-wide">The Process</span>
                <h2 class="display-5 fw-bold mt-2">4 Steps to Your Perfect Smile</h2>
            </div>

            <div class="row g-4 position-relative">
                <!-- Connecting Line for Desktop -->
                <div class="position-absolute top-50 start-0 w-100 border-top border-white opacity-25 d-none d-lg-block z-0"
                    style="transform: translateY(-50%);"></div>

                <div class="col-sm-6 col-lg-3 text-center position-relative z-1 reveal-up">
                    <div class="step-icon-bg bg-white text-teal rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4 shadow hover-scale"
                        style="width: 100px; height: 100px; font-size: 2.5rem;">
                        <i class="fa-solid fa-camera"></i>
                    </div>
                    <h4 class="fw-bold">1. Scan Teeth</h4>
                    <p class="small text-white-50">Book an appointment for a quick 3D scan of your teeth.</p>
                </div>

                <div class="col-sm-6 col-lg-3 text-center position-relative z-1 reveal-up"
                    style="transition-delay: 100ms;">
                    <div class="step-icon-bg bg-white text-teal rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4 shadow hover-scale"
                        style="width: 100px; height: 100px; font-size: 2.5rem;">
                        <i class="fa-solid fa-laptop-medical"></i>
                    </div>
                    <h4 class="fw-bold">2. Design Aligners</h4>
                    <p class="small text-white-50">Our experts create a custom 3D treatment plan for you.</p>
                </div>

                <div class="col-sm-6 col-lg-3 text-center position-relative z-1 reveal-up"
                    style="transition-delay: 200ms;">
                    <div class="step-icon-bg bg-white text-teal rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4 shadow hover-scale"
                        style="width: 100px; height: 100px; font-size: 2.5rem;">
                        <i class="fa-solid fa-face-smile"></i>
                    </div>
                    <h4 class="fw-bold">3. Wear Aligners</h4>
                    <p class="small text-white-50">Receive your custom aligners and wear them diligently.</p>
                </div>

                <div class="col-sm-6 col-lg-3 text-center position-relative z-1 reveal-up"
                    style="transition-delay: 300ms;">
                    <div class="step-icon-bg bg-white text-teal rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4 shadow hover-scale"
                        style="width: 100px; height: 100px; font-size: 2.5rem;">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <h4 class="fw-bold">4. Perfect Smile</h4>
                    <p class="small text-white-50">Show off your new, confident, straight smile to the world!</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits Section -->
    <section id="benefits" class="py-6 bg-light">
        <div class="container py-5">
            <div class="text-center mb-5 reveal-up">
                <span class="text-teal font-monospace text-uppercase small fw-bold tracking-wide">Why Choose Us</span>
                <h2 class="display-5 fw-bold mt-2 text-dark">Aligner Benefits</h2>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-4 reveal-up">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex gap-3 hover-lift">
                        <div class="icon-square bg-blue-light text-teal rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                            style="width: 60px; height: 60px; font-size: 1.5rem;">
                            <i class="fa-solid fa-eye-slash"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark">Invisible</h5>
                            <p class="text-muted small mb-0">Virtually invisible transparent plastic material makes them
                                incredibly discreet.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4 reveal-up" style="transition-delay: 100ms;">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex gap-3 hover-lift">
                        <div class="icon-square bg-blue-light text-teal rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                            style="width: 60px; height: 60px; font-size: 1.5rem;">
                            <i class="fa-solid fa-arrows-rotate"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark">Removable</h5>
                            <p class="text-muted small mb-0">Easily remove aligners for eating, brushing, and flossing.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4 reveal-up" style="transition-delay: 200ms;">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex gap-3 hover-lift">
                        <div class="icon-square bg-blue-light text-teal rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                            style="width: 60px; height: 60px; font-size: 1.5rem;">
                            <i class="fa-solid fa-couch"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark">Comfortable</h5>
                            <p class="text-muted small mb-0">Smooth plastic edges fit snugly without irritating your
                                cheeks or gums.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4 reveal-up">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex gap-3 hover-lift">
                        <div class="icon-square bg-blue-light text-teal rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                            style="width: 60px; height: 60px; font-size: 1.5rem;">
                            <i class="fa-solid fa-utensils"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark">Eat Anything</h5>
                            <p class="text-muted small mb-0">No dietary restrictions since you remove aligners during
                                meals.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4 reveal-up" style="transition-delay: 100ms;">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex gap-3 hover-lift">
                        <div class="icon-square bg-blue-light text-teal rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                            style="width: 60px; height: 60px; font-size: 1.5rem;">
                            <i class="fa-solid fa-toothbrush"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark">Easy Cleaning</h5>
                            <p class="text-muted small mb-0">Maintain great oral hygiene easily by brushing and flossing
                                normally.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4 reveal-up" style="transition-delay: 200ms;">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 d-flex gap-3 hover-lift">
                        <div class="icon-square bg-blue-light text-teal rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                            style="width: 60px; height: 60px; font-size: 1.5rem;">
                            <i class="fa-solid fa-stopwatch"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark">Fast Treatment</h5>
                            <p class="text-muted small mb-0">Typically 6-18 months, often faster than traditional metal
                                braces.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Before & After Section -->
    <section id="before-after" class="py-6">
        <div class="container py-5">
            <div class="text-center mb-5 reveal-up">
                <span class="text-teal font-monospace text-uppercase small fw-bold tracking-wide">Results</span>
