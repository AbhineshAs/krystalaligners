                        <div
                            class="position-absolute top-0 start-0 bg-dark text-white px-3 py-1 rounded-bottom-end z-1 shadow-sm">
                            Before</div>
                        <img src="https://images.unsplash.com/photo-1598256989800-fea5f6c8d0ea?auto=format&fit=crop&q=80&w=800"
                            alt="Before Aligner" class="img-fluid w-100 object-fit-cover hover-zoom-img"
                            style="height: 400px;">
                    </div>
                </div>
                <div class="col-md-6 reveal-up" style="transition-delay: 100ms;">
                    <div
                        class="position-relative overflow-hidden rounded-4 shadow border border-3 border-teal group-hover-zoom">
                        <div
                            class="position-absolute top-0 start-0 bg-teal text-white px-3 py-1 rounded-bottom-end z-1 shadow-sm">
                            After</div>
                        <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=800"
