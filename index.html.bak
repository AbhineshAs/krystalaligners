    <!-- Contact Section -->
    <section id="contact" class="py-6 bg-light">
        <div class="container py-5">
            <div class="row g-5 bg-white rounded-4 shadow-sm overflow-hidden p-0 m-0">
                <!-- Left: Form -->
                <div class="col-lg-6 p-4 p-md-5 reveal-up">
                    <span class="text-teal font-monospace text-uppercase small fw-bold tracking-wide">Get In
                        Touch</span>
                    <h2 class="display-6 fw-bold mt-2 mb-4 text-dark">Book Your Free Scan</h2>
                    <form id="contactForm">
                        <div class="mb-3">
                            <label for="name" class="form-label text-secondary small fw-medium">Full Name</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" id="name"
                                placeholder="John Doe" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label text-secondary small fw-medium">Email Address</label>
                            <input type="email" class="form-control form-control-lg bg-light border-0" id="email"
                                placeholder="john@example.com" required>
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label text-secondary small fw-medium">Phone Number</label>
                            <input type="tel" class="form-control form-control-lg bg-light border-0" id="phone"
                                placeholder="(123) 456-7890" required>
                        </div>
                        <div class="mb-4">
                            <label for="message" class="form-label text-secondary small fw-medium">Message
                                (Optional)</label>
                            <textarea class="form-control form-control-lg bg-light border-0" id="message" rows="3"
                                placeholder="I'm interested in clear aligners..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-teal btn-lg w-100 rounded-pill shadow-sm">Send
                            Request</button>
                    </form>
                </div>
                <!-- Right: Map/Info -->
                <div class="col-lg-6 p-0 position-relative reveal-up" style="transition-delay: 200ms;">
                    <!-- Embedded Map Placeholder -->
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1000!2d-122.08!3d37.42!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzfCsDI1JzEyLjAiTiAxMjLCsDA0JzQ4LjAiVw!5e0!3m2!1sen!2sus!4v1611234567890!5m2!1sen!2sus"
                        width="100%" height="100%" style="border:0; min-height: 400px;" allowfullscreen=""
                        loading="lazy"></iframe>

                    <!-- Floating Contact Box -->
                    <div
                        class="bg-white p-4 rounded-4 shadow position-absolute bottom-0 start-50 translate-middle-x mb-4 w-75 contact-info-box">
                        <h5 class="fw-bold mb-3 text-dark">Clinic Info</h5>
                        <ul class="list-unstyled mb-0 d-flex flex-column gap-2 small text-secondary">
                            <li><i class="fa-solid fa-location-dot text-teal me-2 w-15"></i> 123 Smile Ave, NY 10001
                            </li>
                            <li><i class="fa-solid fa-phone text-teal me-2 w-15"></i> +1 (555) 123-4567</li>
                            <li><i class="fa-solid fa-envelope text-teal me-2 w-15"></i> hello@pristinealigner.com</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

